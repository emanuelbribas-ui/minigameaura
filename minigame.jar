package com.serpens.checkin;

import net.fabricmc.api.ModInitializer;
import net.fabricmc.fabric.api.command.v2.CommandRegistrationCallback;
import net.minecraft.server.command.CommandManager;
import net.minecraft.text.Text;
import java.io.File;
import java.sql.*;
import java.time.LocalDate;

public class SerpensCheckin implements ModInitializer {
    private Connection conn;

    @Override
    public void onInitialize() {
        try {
            // Garante que o banco seja criado na pasta minigames na raiz do servidor
            File dbFile = new File("minigames/database.sqlite");
            conn = DriverManager.getConnection("jdbc:sqlite:" + dbFile.getAbsolutePath());
            conn.createStatement().execute("CREATE TABLE IF NOT EXISTS checkins (uuid VARCHAR(36) PRIMARY KEY, data VARCHAR(10), streak INTEGER)");
        } catch (Exception e) { e.printStackTrace(); }

        CommandRegistrationCallback.EVENT.register((dispatcher, reg, env) -> dispatcher.register(CommandManager.literal("checkin").executes(ctx -> {
            String uuid = ctx.getSource().getPlayer().getUuidAsString();
            String hoje = LocalDate.now().toString();
            try {
                PreparedStatement ps = conn.prepareStatement("SELECT * FROM checkins WHERE uuid = ?");
                ps.setString(1, uuid);
                ResultSet rs = ps.executeQuery();
                int streak = (rs.next() && LocalDate.parse(rs.getString("data")).plusDays(1).equals(LocalDate.now())) ? rs.getInt("streak") + 1 : 1;
                if (rs.getRow() > 0 && hoje.equals(rs.getString("data"))) return 1;
                conn.prepareStatement("INSERT OR REPLACE INTO checkins VALUES ('" + uuid + "', '" + hoje + "', " + streak + ")").execute();
                ctx.getSource().getPlayer().sendMessage(Text.literal("§5[Serpens] Check-in feito! Streak: " + streak), false);
                ctx.getSource().getServer().getCommandManager().executeWithPrefix(ctx.getSource().getServer().getCommandSource(), "eco give " + ctx.getSource().getPlayer().getName().getString() + " 1000");
            } catch (Exception e) { e.printStackTrace(); }
            return 1;
        })));
    }
}
